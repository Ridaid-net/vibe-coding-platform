AI_GATEWAY_API_KEY=

# RODAID — Hito 1: Autenticacion Definitiva.
# Secreto de firma de los JWT (AccessToken). OBLIGATORIO en produccion (modo
# LIVE de MercadoPago). En preview/STUB se usa un secreto de desarrollo si falta.
# Usar un valor largo y aleatorio (p. ej. `openssl rand -base64 48`).
# Hito 19: la Edge Function `auth-admin` valida la FIRMA del JWT con este mismo
# secreto (o AUTH_SECRET) para el control de acceso al panel en el borde.
JWT_SECRET=
# Token de sistema para endpoints de back-office / funciones programadas.
# Hito 19: la Edge Function `auth-admin` lo acepta via header `x-admin-token`
# para dejar pasar las tareas programadas que invocan /api/v1/admin/*.
RODAID_ADMIN_TOKEN=

# RODAID — Anclaje de Identidad en la BFA (Hito 4 / Blockchain).
# Sin estas variables el anclaje opera en modo STUB (simulado) y no toca la red.
# Con las tres primeras definidas, opera ONCHAIN contra la BFA real.
BFA_RPC_URL=
BFA_PRIVATE_KEY=
BFA_CIT_CONTRACT=
# Opcionales:
BFA_CIT_CUSTODY_WALLET=
BFA_OWNER_PRIVATE_KEY=

# RODAID — Hito 7: Verificador Publico.
# Limite de consultas por IP y ventana (60s) del endpoint abierto
# GET /api/v1/verificar/:serial. Protege contra la enumeracion de seriales por
# fuerza bruta. Por defecto 20 consultas/min.
RODAID_VERIFICAR_RATE_LIMIT=20

# RODAID — Certificado Digital de Propiedad y Verificacion (PDF firmado).
# Autoridad firmante del certificado (firma detached PKCS#7 incrustada en el PDF).
# Sin estas variables la firma opera en modo DEV: se genera un certificado
# autofirmado efimero para ejercitar el flujo en preview. Con el certificado y la
# clave privada de la autoridad de RODAID, la firma se emite con esa identidad.
# Pegar el PEM completo (se admiten saltos de linea como \n).
RODAID_CERT_PEM=
RODAID_CERT_KEY_PEM=
# Opcionales:
RODAID_CERT_KEY_PASSPHRASE=
RODAID_CERT_CHAIN_PEM=
# URL base publica del sitio (para el QR del certificado y las fotos). Si falta,
# se deriva del origen del propio request.
RODAID_BASE_URL=
# Ruta opcional a la tipografia de marca (Bianco Sport) para los titulos del PDF.
# Si no esta, el certificado usa una tipografia estandar limpia.
RODAID_PDF_FONT_PATH=

# RODAID — Hito 11: Firma digital de actas de inspeccion (Web Crypto / PKCS#12).
# Credencial de la Autoridad de Inspeccion que firma cada acta fisica. Bundle
# PKCS#12 (.p12/.pfx) con la clave privada + el certificado X.509, codificado en
# base64. Sin esta variable la firma opera en modo DEV: se genera un bundle
# PKCS#12 autofirmado efimero para ejercitar el flujo en preview. Con la
# credencial real, las actas se firman con esa identidad sin tocar codigo.
#   base64:  openssl pkcs12 ... -export -out acta.p12  &&  base64 -w0 acta.p12
RODAID_INSPECTOR_P12_BASE64=
RODAID_INSPECTOR_P12_PASSPHRASE=

# RODAID — Hito 10: Notificaciones Push (Web Push / VAPID).
# Claves VAPID (curva P-256, base64url) para firmar las notificaciones push.
# Generables con `npx web-push generate-vapid-keys` o con
# crypto.generateKeyPairSync('ec', { namedCurve: 'prime256v1' }).
# Sin estas variables, en preview/DEV se deriva un par determinista del secreto
# de autenticacion para ejercitar el flujo de punta a punta. En produccion,
# configurar un par estable para no invalidar las suscripciones existentes.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contacto del servidor de aplicacion (mailto: o https://). Por defecto
# mailto:soporte@rodaid.app.
VAPID_SUBJECT=
# RODAID — Hito 8: Mapa de Calor y Analitica de Seguridad.
# Todas las posiciones se RECORTAN (clipping) a una grilla de ~barrio antes de
# persistirse: el mapa nunca revela una direccion puntual. Estas variables
# ajustan el motor; con sus valores por defecto el dashboard ya funciona.
# Tamano de celda de la grilla en grados (~0.0045° ≈ 500 m). Mas chico = mas
# detalle pero menos anonimato; mas grande = mas privacidad.
ANALITICA_GRID_DEG=0.0045
# Minimo de eventos por celda para publicar la capa de consultas (k-anonimato).
ANALITICA_KANON
cat > /tmp/env-example-parte2.txt << 'ENVEOF2'
# RODAID — Hito 8: Mapa de Calor y Analitica de Seguridad.
# Todas las posiciones se RECORTAN (clipping) a una grilla de ~barrio antes de
# persistirse: el mapa nunca revela una direccion puntual. Estas variables
# ajustan el motor; con sus valores por defecto el dashboard ya funciona.
# Tamano de celda de la grilla en grados (~0.0045° ≈ 500 m). Mas chico = mas
# detalle pero menos anonimato; mas grande = mas privacidad.
ANALITICA_GRID_DEG=0.0045
# Minimo de eventos por celda para publicar la capa de consultas (k-anonimato).
ANALITICA_KANON_MIN=1
# Umbral critico de consultas por barrio/ventana para marcar un "Punto Caliente".
ANALITICA_HOTSPOT_UMBRAL=12
# Ventana (horas) sobre la que se evalua el volumen de un punto caliente.
ANALITICA_HOTSPOT_VENTANA_HORAS=72

# RODAID — Hito 14: Garaje Digital (mapa de calor PERSONAL del usuario).
# Minimo de eventos por celda para dibujar el mapa personal (k-anonimato). Mas
# estricto que el publico: un evento aislado podria caer cerca del domicilio del
# usuario, asi que por defecto se exige al menos 2. El recorte a barrio reusa
# ANALITICA_GRID_DEG.
GARAJE_MAPA_KANON_MIN=2

# RODAID — Hito 15: RODAID-GPT (asistente experto en seguridad y gestion ciclista).
# El asistente usa Claude Sonnet a traves del Netlify AI Gateway: las credenciales
# (ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL) las inyecta Netlify automaticamente y
# NUNCA se exponen al cliente; el backend es el unico intermediario.
# Cuota mensual de consultas REALES por usuario (rate limiting). Por defecto 100.
RODAID_GPT_CUOTA_MENSUAL=100
# Vida util (horas) de una respuesta cacheada en Netlify Blobs. Por defecto 6.
RODAID_GPT_CACHE_TTL_HORAS=6
# Tope de tokens de la respuesta del modelo. Por defecto 1024.
RODAID_GPT_MAX_TOKENS=1024

# RODAID — Hito 9: Integracion Institucional MxM (Mendoza por Mi).
# Identidad unificada del Gobierno de Mendoza via OIDC (Authorization Code + PKCE).
# Sin estas variables el login con MxM opera en modo SIMULADO (sandbox interno)
# para ejercitar el flujo completo en preview sin tocar datos reales del Gobierno.
# Con MXM_ISSUER_URL + MXM_CLIENT_ID + MXM_CLIENT_SECRET definidos, opera en LIVE
# contra el IDP real. Apuntar el issuer al sandbox del Gobierno antes de produccion
# (p. ej. https://sandbox.mxm.mendoza.gov.ar).
MXM_ISSUER_URL=
MXM_CLIENT_ID=
MXM_CLIENT_SECRET=
# Opcionales: si el IDP no sigue las rutas estandar de OIDC, se pueden fijar.
MXM_AUTHORIZATION_ENDPOINT=
MXM_TOKEN_ENDPOINT=
MXM_JWKS_URI=
# URL de callback registrada en el IDP. Si falta, se deriva de RODAID_BASE_URL o
# del origen del request: <base>/api/v1/auth/mxm/callback
MXM_REDIRECT_URI=
# Scopes solicitados al IDP. Por defecto: "openid profile email".
MXM_SCOPES=
# CUILs (o `sub`) de funcionarios que ademas se elevan a rol admin (coma-separados).
# El resto de los funcionarios publicos reciben el rol inspector automaticamente.
MXM_ADMIN_CUILS=

# RODAID — Hito 12: Integracion Institucional con el Ministerio de Seguridad.
# Protocolo mTLS + cross-reference + webhook inverso de recupero.
# Sin estas variables, el modulo opera en modo SIMULADO (DEV): se deriva una CA
# efimera ESTABLE del secreto de la app y se puede emitir una credencial de
# cliente de demo en GET /api/seguridad/institucional/credencial-demo para
# ejercitar el flujo mTLS de punta a punta en preview. Al configurar la CA real,
# la validacion opera contra ella sin tocar codigo.
#
# CA (Autoridad Certificadora) del Ministerio: uno o varios certificados PEM
# concatenados. Solo se aceptan certificados de cliente emitidos por esta CA.
RODAID_MINISTERIO_CA_PEM=
# Clave AES-256 para el cifrado en reposo de datos sensibles recibidos del
# Ministerio (DNI, payloads de recupero). 32 bytes en base64 o 64 hex chars. Sin
# definir, se deriva una clave estable del secreto de la app (solo preview).
RODAID_MINISTERIO_AES_KEY=
# Aislamiento de red (defensa en profundidad): IPs autorizadas a consumir los
# endpoints institucionales, separadas por coma. Vacio = sin filtro de IP (se
# confia en el aislamiento de red de la plataforma + mTLS).
RODAID_MINISTERIO_IP_ALLOWLIST=
# TTL (segundos) de la cache de denuncias activas que sostiene el SLA < 2 s del
# cross-reference. Por defecto 60.
RODAID_MINISTERIO_CACHE_TTL_SEG=60
# Timeout (ms) del fetch de cross-reference contra el Ministerio (clasificacion
# CIT Express, Fase 2). Por defecto 4000 -- debe quedar por debajo del
# Promise.race de cit-express.service.ts (se deriva de este valor + margen) para
# que el fail-closed a ROJO no deje conexiones colgadas.
RODAID_CROSSREF_TIMEOUT_MS=4000
# RODAID — Hito 13: RODAID PAY (motor de pagos y compensaciones).
# El gateway de pago del marketplace (escrow) usa MercadoPago. El access token se
# toma SIEMPRE de la variable de entorno; NUNCA se hardcodea. Sin token el escrow
# opera en modo STUB (simulado); con TEST-... en SANDBOX y con APP_USR-... en LIVE.
RODAID_MP_ACCESS_TOKEN=
# Secreto para validar la firma del webhook de MercadoPago (X-Signature) en LIVE.
RODAID_MP_WEBHOOK_SECRET=
#
# Compensaciones (Fase 0 — Pricing CIT):
# La tasa CIT oficial y el % de retribucion al Taller Aliado ya NO se leen de
# variables de entorno: viven en la tabla `parametros_pricing_cit`
# (claves 'tasa_cit_oficial_ars' y 'retribucion_aliado_pct_generico'),
# editables en caliente sin redeploy. Ver migracion
# 20260708000001_create_parametros_pricing_cit.sql.
#
# Tasa CIT Oficial — pasarela de pagos estatal (Mendoza por Mi). Sin estas
# variables el pago de la tasa opera en modo SIMULADO (pasarela interna) para
# ejercitar el flujo de punta a punta en preview. Con ambas definidas, opera en
# LIVE contra la pasarela estatal real.
MXM_PAGOS_BASE_URL=
MXM_PAGOS_API_KEY=
# Secreto para validar la firma del webhook de la pasarela estatal (HMAC-SHA256).
MXM_PAGOS_WEBHOOK_SECRET=

# RODAID — Hito 16: RODAID Open-Connect (apertura al ecosistema externo).
# El acceso de terceros se basa en OAuth2/OIDC con consentimiento expreso del
# usuario. Estas variables son OPCIONALES: sin ellas el modulo opera de punta a
# punta en preview (claves derivadas del secreto de la app, igual que el resto
# del proyecto) y al definirlas opera en produccion sin tocar codigo.
#
# URL base publica del sitio (para issuer/redirect/verifier del flujo OAuth y de
# las Credenciales Verificables). Si esta vacia, se deriva del request.
RODAID_BASE_URL=
# Vida (segundos) del access token OAuth2 que consumen los terceros. Por defecto 3600.
RODAID_OAUTH_TOKEN_TTL_SEG=3600
# Clave PRIVADA de firma de las Credenciales Verificables (W3C VC-JWT, EdDSA), en
# formato JWK (OKP/Ed25519) como JSON. La clave publica se publica en
# /.well-known/jwks.json y /.well-known/did.json. Sin esta variable se deriva una
# clave Ed25519 estable del secreto de la app (preview).
RODAID_VC_SIGNING_JWK=

# RODAID — Hito 17: RODAID-IoT (telemetria, tiempo real y mantenimiento predictivo).
# La integracion de dispositivos GPS/sensores IoT. Todas estas variables son
# OPCIONALES: sin ellas el modulo opera de punta a punta en preview (claves
# derivadas del secreto de la app, igual que el resto del proyecto) y al definirlas
# opera en produccion sin tocar codigo.
#
# Clave AES-256 (32 bytes en base64 o 64 hex) para el cifrado de EXTREMO A EXTREMO
# de la posicion precisa de la telemetria. Es INDEPENDIENTE de la del Ministerio.
# Sin definir, se deriva una clave estable del secreto de la app (solo preview).
RODAID_IOT_AES_KEY=
# Retencion (dias) de la posicion precisa en la traza historica antes de
# anonimizarla (borrar la posicion cifrada y dejar solo el geo recortado a barrio,
# como el mapa de calor). Por defecto 30.
RODAID_IOT_RETENCION_DIAS=30
# Ventana (minutos) para considerar un dispositivo "conectado" (reporto reciente).
RODAID_IOT_ONLINE_VENTANA_MIN=60
# Umbral de bateria (%) por debajo del cual el backend prioriza el ahorro de
# energia (espacia el reporte) para que la bateria dure >= 6 meses. Por defecto 15.
RODAID_IOT_BATERIA_BAJA_PCT=15
# Mantenimiento predictivo (IA): cantidad de muestras del acelerometro a analizar
# y limite de tokens de la respuesta del modelo.
RODAID_IOT_MANT_MUESTRAS=200
RODAID_IOT_MANT_MAX_TOKENS=700
# Reporte de "robo en curso" al Ministerio de Seguridad (Hito 12) con ubicacion en
# tiempo real. Sin URL, el aviso opera en modo SIMULADO (queda en el log). Con la
# URL real, RODAID hace el POST autenticado con la API key (si se define).
RODAID_MINISTERIO_ROBO_URL=
RODAID_MINISTERIO_ROBO_API_KEY=
# RODAID — Hito 18: Denuncia Ciudadana con Validacion de Documento Oficial (MPF).
# Integra la denuncia ciudadana con el PDF oficial del Ministerio Publico Fiscal.
# Todas estas variables son OPCIONALES: sin ellas el modulo opera de punta a punta
# en preview (claves derivadas del secreto de la app, Ministerio en modo simulado)
# y al definirlas opera en produccion sin tocar codigo.
#
# Clave AES-256 (32 bytes en base64 o 64 hex) del BUCKET CIFRADO donde se guarda el
# PDF de la denuncia en reposo. Es INDEPENDIENTE de la del Ministerio y la IoT.
# Sin definir, se deriva una clave estable del secreto de la app (solo preview).
RODAID_DENUNCIA_AES_KEY=
# Clave AES-256 (32 bytes en base64 o 64 hex) del BUCKET CIFRADO donde se guardan
# las fotos de componentes tokenizados (Checklist de 20 puntos, "CIT Completo
# Plus"). INDEPENDIENTE de las demas. Sin definir, se deriva una clave estable
# del secreto de la app (solo preview).
RODAID_INSPECCION_AES_KEY=
# Clave AES-256 (32 bytes en base64 o 64 hex) de los tokens OAuth de Strava
# (access_token/refresh_token en oauth_connections, Hito 17 BYOD). INDEPENDIENTE
# de las demas. Sin definir, se deriva una clave estable del secreto de la app
# (solo preview).
RODAID_STRAVA_AES_KEY=
# Vida (segundos) del token del LINK SEGURO al PDF que recibe el Ministerio. Por
# defecto 604800 (7 dias), para el acceso de la autoridad en tiempo real.
RODAID_DENUNCIA_DOC_TTL_SEG=604800
# Webhook al Ministerio de Seguridad para el aviso de DENUNCIA JUDICIAL ACTIVA
# (incluye el link seguro al PDF). Sin URL, el aviso opera en modo SIMULADO (queda
# en el log). Si no se define, se usa RODAID_MINISTERIO_ROBO_URL como respaldo.
RODAID_MINISTERIO_DENUNCIA_URL=
RODAID_MINISTERIO_DENUNCIA_API_KEY=
# Timeout (ms) de la notificacion al Ministerio (aviso de denuncia judicial y
# reporte de robo en curso). Por defecto 8000. Si falla o se cuelga, se
# reintenta automaticamente via ministerio-notificacion-worker.mts (cada 5 min).
RODAID_MINISTERIO_TIMEOUT_MS=8000
# Servicio OCR externo (opcional) para PDFs ESCANEADOS sin texto. Contrato: POST
# del PDF (application/pdf) -> JSON { text }. Sin OCR, un PDF ilegible deja la
# denuncia EN_REVISION (no bloquea automaticamente).
RODAID_OCR_URL=
RODAID_OCR_API_KEY=

# RODAID — Asistente de Soporte Tecnico y Legal del Footer (widget FAQ publico).
# Asistente ABIERTO (sin autenticacion) de preguntas frecuentes sobre el
# ecosistema. Distinto de RODAID-GPT (Hito 15), que es personal y autenticado.
# Todas estas variables son OPCIONALES: sin ellas el modulo opera de punta a
# punta en preview y al definirlas opera en produccion sin tocar codigo.
#
# Modelo del asistente FAQ (debe estar soportado por el AI Gateway de Netlify).
# Por defecto Claude Haiku 4.5 (rapido y economico para un widget publico).
RODAID_FAQ_MODELO=claude-haiku-4-5
# Tope de tokens de la respuesta del asistente FAQ.
RODAID_FAQ_MAX_TOKENS=700
# Rate limiting por IP del endpoint publico de IA (anti-abuso): maximo de
# consultas REALES por ventana y duracion de la ventana en segundos.
RODAID_FAQ_RATE_MAX=20
RODAID_FAQ_RATE_VENTANA_SEG=600
# Vida (horas) de una respuesta cacheada de FAQ frecuente en Netlify Blobs.
RODAID_FAQ_CACHE_TTL_HORAS=24
# Sal para hashear la IP del rate limiting (si no se define, se usa
# RODAID_APP_SECRET). La IP nunca se persiste en claro, solo su hash.
RODAID_FAQ_IP_SALT=

# RODAID — Asistente Oficial de Soporte y Consultoria Legal.
# Asistente ABIERTO (sin autenticacion) cuyo conocimiento se limita EXCLUSIVAMENTE
# al corpus legal: Terminos y Condiciones, Protocolo de Emision del CIT (Regla de
# las 72 horas, Declaracion Jurada de Licitud) y normativa de seguridad/datos.
# Distinto del widget de FAQ general. Todas las variables son OPCIONALES: sin ellas
# el modulo opera en preview y al definirlas opera en produccion sin tocar codigo.
#
# Modelo del asistente legal (debe estar soportado por el AI Gateway de Netlify).
# Por defecto Claude Sonnet 4.6: un asistente legal exige mas rigor que el FAQ.
RODAID_LEGAL_MODELO=claude-sonnet-4-6
# Tope de tokens de la respuesta del asistente legal.
RODAID_LEGAL_MAX_TOKENS=900
# Rate limiting por IP del endpoint publico de IA (anti-abuso): maximo de
# consultas REALES por ventana y duracion de la ventana en segundos.
RODAID_LEGAL_RATE_MAX=20
RODAID_LEGAL_RATE_VENTANA_SEG=600
# Vida (horas) de una respuesta cacheada de consulta legal frecuente en Netlify Blobs.
RODAID_LEGAL_CACHE_TTL_HORAS=24
# Sal para hashear la IP del rate limiting (si no se define, se usa
# RODAID_APP_SECRET). La IP nunca se persiste en claro, solo su hash.
RODAID_LEGAL_IP_SALT=

# RODAID — Hito 19: Dashboard de Administracion (Operaciones / SysAdmin).
# Panel de administracion de escala provincial con MFA obligatoria, sub-roles
# (SuperAdmin / Auditor / Operador de Soporte) y bitacora inmutable. Todas las
# variables son OPCIONALES: sin ellas el modulo opera de punta a punta en preview
# (sub-rol superadmin demo + codigo TOTP demo) y al definirlas opera en
# produccion sin tocar codigo.
#
# Emails (coma-separados) que se aprovisionan como SuperAdmin al ingresar al
# panel. En LIVE, el resto de los admins arranca con el minimo privilegio
# (Operador de Soporte). En preview todos los admins demo son superadmin.
RODAID_SUPERADMIN_EMAILS=
# Vida (segundos) del token de step-up MFA del panel (por defecto 1800 = 30 min).
# Vencido el token, el administrador debe verificar de nuevo su segundo factor.
RODAID_ADMIN_MFA_TTL_SEG=1800

# RODAID — Indexacion automatica de precios CIT al dolar oficial BNA.
# Email al que se notifica cada ciclo abortado (fuente caida, anomalia de
# cotizacion). OPCIONAL: sin definir, cae a contactoarribaeleste@gmail.com
# (la cuenta personal de Federico) por defecto.
RODAID_PRICING_ALERTA_EMAIL=

# RODAID — Modulo 4 (CIT): Configuracion Final · Acunacion del NFT en BFA.
# Anclaje del Certificado de Identidad Tecnica como NFT en la Blockchain Federal
# Argentina. La construccion del NFT (token id + metadata) es deterministica y no
# requiere configuracion; la submission on-chain se delega a un gateway/relayer.
# Sin BFA_GATEWAY_URL, el certificado queda con su NFT preparado (PENDIENTE) a la
# espera, sin inventar transacciones.
BFA_GATEWAY_URL=
BFA_GATEWAY_API_KEY=
BFA_CONTRATO=
BFA_CHAIN_ID=
BFA_RED_NOMBRE=
BFA_EXPLORER_URL=
BFA_TIMEOUT_MS=

# Modelo Custodial RODAID: wallet a la que se acuna el NFT cuando el propietario no
# aporta la suya. Si no se configura, se usa un identificador custodial por ciclista.
RODAID_CUSTODIAL_WALLET=

# Subida de metadata ERC-721 a IPFS (background, fuera de la transaccion de mint).
# Sin IPFS_API_URL no se sube nada (no se inventa un CID).
IPFS_API_URL=
IPFS_API_KEY=
IPFS_TIMEOUT_MS=

# Motor de Notificaciones — canal EMAIL (Resend). Sin estas dos variables el canal
# email queda deshabilitado (la notificacion in-app igual se guarda siempre).
RESEND_API_KEY=
RESEND_FROM=

# Motor de Notificaciones — canal PUSH (Firebase Cloud Messaging, HTTP legacy).
FCM_SERVER_KEY=

# Timeout de los canales externos de notificacion, en milisegundos (defecto 8000).
NOTIF_TIMEOUT_MS=

# URL publica de la app para los enlaces CTA de las notificaciones (defecto https://rodaid.app).
RODAID_APP_URL=
