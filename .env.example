AI_GATEWAY_API_KEY=

# RODAID — Hito 1: Autenticacion Definitiva.
# Secreto de firma de los JWT (AccessToken). OBLIGATORIO en produccion (modo
# LIVE de MercadoPago). En preview/STUB se usa un secreto de desarrollo si falta.
# Usar un valor largo y aleatorio (p. ej. `openssl rand -base64 48`).
JWT_SECRET=
# Token de sistema para endpoints de back-office / funciones programadas.
RODAID_ADMIN_TOKEN=

# RODAID — Anclaje de Identidad en la BFA (Hito 4 / Blockchain).
# Sin estas variables el anclaje opera en modo STUB (simulado) y no toca la red.
# Con las tres primeras definidas, opera ONCHAIN contra la BFA real.
BFA_RPC_URL=
BFA_PRIVATE_KEY=
BFA_CIT_CONTRACT=
# Opcionales:
BFA_CIT_CUSTODY_WALLET=
BFA_OWNER_PRIVATE_KEY=

# RODAID — Hito 7: Verificador Publico.
# Limite de consultas por IP y ventana (60s) del endpoint abierto
# GET /api/v1/verificar/:serial. Protege contra la enumeracion de seriales por
# fuerza bruta. Por defecto 20 consultas/min.
RODAID_VERIFICAR_RATE_LIMIT=20

# RODAID — Certificado Digital de Propiedad y Verificacion (PDF firmado).
# Autoridad firmante del certificado (firma detached PKCS#7 incrustada en el PDF).
# Sin estas variables la firma opera en modo DEV: se genera un certificado
# autofirmado efimero para ejercitar el flujo en preview. Con el certificado y la
# clave privada de la autoridad de RODAID, la firma se emite con esa identidad.
# Pegar el PEM completo (se admiten saltos de linea como \n).
RODAID_CERT_PEM=
RODAID_CERT_KEY_PEM=
# Opcionales:
RODAID_CERT_KEY_PASSPHRASE=
RODAID_CERT_CHAIN_PEM=
# URL base publica del sitio (para el QR del certificado y las fotos). Si falta,
# se deriva del origen del propio request.
RODAID_BASE_URL=
# Ruta opcional a la tipografia de marca (Bianco Sport) para los titulos del PDF.
# Si no esta, el certificado usa una tipografia estandar limpia.
RODAID_PDF_FONT_PATH=

# RODAID — Hito 11: Firma digital de actas de inspeccion (Web Crypto / PKCS#12).
# Credencial de la Autoridad de Inspeccion que firma cada acta fisica. Bundle
# PKCS#12 (.p12/.pfx) con la clave privada + el certificado X.509, codificado en
# base64. Sin esta variable la firma opera en modo DEV: se genera un bundle
# PKCS#12 autofirmado efimero para ejercitar el flujo en preview. Con la
# credencial real, las actas se firman con esa identidad sin tocar codigo.
#   base64:  openssl pkcs12 ... -export -out acta.p12  &&  base64 -w0 acta.p12
RODAID_INSPECTOR_P12_BASE64=
RODAID_INSPECTOR_P12_PASSPHRASE=

# RODAID — Hito 10: Notificaciones Push (Web Push / VAPID).
# Claves VAPID (curva P-256, base64url) para firmar las notificaciones push.
# Generables con `npx web-push generate-vapid-keys` o con
# crypto.generateKeyPairSync('ec', { namedCurve: 'prime256v1' }).
# Sin estas variables, en preview/DEV se deriva un par determinista del secreto
# de autenticacion para ejercitar el flujo de punta a punta. En produccion,
# configurar un par estable para no invalidar las suscripciones existentes.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contacto del servidor de aplicacion (mailto: o https://). Por defecto
# mailto:soporte@rodaid.app.
VAPID_SUBJECT=

# RODAID — Hito 8: Mapa de Calor y Analitica de Seguridad.
# Todas las posiciones se RECORTAN (clipping) a una grilla de ~barrio antes de
# persistirse: el mapa nunca revela una direccion puntual. Estas variables
# ajustan el motor; con sus valores por defecto el dashboard ya funciona.
# Tamano de celda de la grilla en grados (~0.0045° ≈ 500 m). Mas chico = mas
# detalle pero menos anonimato; mas grande = mas privacidad.
ANALITICA_GRID_DEG=0.0045
# Minimo de eventos por celda para publicar la capa de consultas (k-anonimato).
ANALITICA_KANON_MIN=1
# Umbral critico de consultas por barrio/ventana para marcar un "Punto Caliente".
ANALITICA_HOTSPOT_UMBRAL=12
# Ventana (horas) sobre la que se evalua el volumen de un punto caliente.
ANALITICA_HOTSPOT_VENTANA_HORAS=72


# RODAID — Hito 14: Garaje Digital (mapa de calor PERSONAL del usuario).
# Minimo de eventos por celda para dibujar el mapa personal (k-anonimato). Mas
# estricto que el publico: un evento aislado podria caer cerca del domicilio del
# usuario, asi que por defecto se exige al menos 2. El recorte a barrio reusa
# ANALITICA_GRID_DEG.
GARAJE_MAPA_KANON_MIN=2

# RODAID — Hito 15: RODAID-GPT (asistente experto en seguridad y gestion ciclista).
# El asistente usa Claude Sonnet a traves del Netlify AI Gateway: las credenciales
# (ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL) las inyecta Netlify automaticamente y
# NUNCA se exponen al cliente; el backend es el unico intermediario.
# Cuota mensual de consultas REALES por usuario (rate limiting). Por defecto 100.
RODAID_GPT_CUOTA_MENSUAL=100
# Vida util (horas) de una respuesta cacheada en Netlify Blobs. Por defecto 6.
RODAID_GPT_CACHE_TTL_HORAS=6
# Tope de tokens de la respuesta del modelo. Por defecto 1024.
RODAID_GPT_MAX_TOKENS=1024



# RODAID — Hito 9: Integracion Institucional MxM (Mendoza por Mi).
# Identidad unificada del Gobierno de Mendoza via OIDC (Authorization Code + PKCE).
# Sin estas variables el login con MxM opera en modo SIMULADO (sandbox interno)
# para ejercitar el flujo completo en preview sin tocar datos reales del Gobierno.
# Con MXM_ISSUER_URL + MXM_CLIENT_ID + MXM_CLIENT_SECRET definidos, opera en LIVE
# contra el IDP real. Apuntar el issuer al sandbox del Gobierno antes de produccion
# (p. ej. https://sandbox.mxm.mendoza.gov.ar).
MXM_ISSUER_URL=
MXM_CLIENT_ID=
MXM_CLIENT_SECRET=
# Opcionales: si el IDP no sigue las rutas estandar de OIDC, se pueden fijar.
MXM_AUTHORIZATION_ENDPOINT=
MXM_TOKEN_ENDPOINT=
MXM_JWKS_URI=
# URL de callback registrada en el IDP. Si falta, se deriva de RODAID_BASE_URL o
# del origen del request: <base>/api/v1/auth/mxm/callback
MXM_REDIRECT_URI=
# Scopes solicitados al IDP. Por defecto: "openid profile email".
MXM_SCOPES=
# CUILs (o `sub`) de funcionarios que ademas se elevan a rol admin (coma-separados).
# El resto de los funcionarios publicos reciben el rol inspector automaticamente.
MXM_ADMIN_CUILS=




# RODAID — Hito 12: Integracion Institucional con el Ministerio de Seguridad.
# Protocolo mTLS + cross-reference + webhook inverso de recupero.
# Sin estas variables, el modulo opera en modo SIMULADO (DEV): se deriva una CA
# efimera ESTABLE del secreto de la app y se puede emitir una credencial de
# cliente de demo en GET /api/seguridad/institucional/credencial-demo para
# ejercitar el flujo mTLS de punta a punta en preview. Al configurar la CA real,
# la validacion opera contra ella sin tocar codigo.
#
# CA (Autoridad Certificadora) del Ministerio: uno o varios certificados PEM
# concatenados. Solo se aceptan certificados de cliente emitidos por esta CA.
RODAID_MINISTERIO_CA_PEM=
# Clave AES-256 para el cifrado en reposo de datos sensibles recibidos del
# Ministerio (DNI, payloads de recupero). 32 bytes en base64 o 64 hex chars. Sin
# definir, se deriva una clave estable del secreto de la app (solo preview).
RODAID_MINISTERIO_AES_KEY=
# Aislamiento de red (defensa en profundidad): IPs autorizadas a consumir los
# endpoints institucionales, separadas por coma. Vacio = sin filtro de IP (se
# confia en el aislamiento de red de la plataforma + mTLS).
RODAID_MINISTERIO_IP_ALLOWLIST=
# TTL (segundos) de la cache de denuncias activas que sostiene el SLA < 2 s del
# cross-reference. Por defecto 60.
RODAID_MINISTERIO_CACHE_TTL_SEG=60

# RODAID — Hito 13: RODAID PAY (motor de pagos y compensaciones).
# El gateway de pago del marketplace (escrow) usa MercadoPago. El access token se
# toma SIEMPRE de la variable de entorno; NUNCA se hardcodea. Sin token el escrow
# opera en modo STUB (simulado); con TEST-... en SANDBOX y con APP_USR-... en LIVE.
RODAID_MP_ACCESS_TOKEN=
# Secreto para validar la firma del webhook de MercadoPago (X-Signature) en LIVE.
RODAID_MP_WEBHOOK_SECRET=
#
# Compensaciones:
# Tasa CIT oficial (ARS) que se cobra por la verificacion. Por defecto 8500.
RODAID_TASA_CIT_ARS=8500
# Parte proporcional de la tasa CIT que recibe el Taller Aliado que valido la bici
# (fraccion en [0,1]). Por defecto 0.30 (30%).
RODAID_RETRIBUCION_ALIADO_PCT=0.3
#
# Tasa CIT Oficial — pasarela de pagos estatal (Mendoza por Mi). Sin estas
# variables el pago de la tasa opera en modo SIMULADO (pasarela interna) para
# ejercitar el flujo de punta a punta en preview. Con ambas definidas, opera en
# LIVE contra la pasarela estatal real.
MXM_PAGOS_BASE_URL=
MXM_PAGOS_API_KEY=
# Secreto para validar la firma del webhook de la pasarela estatal (HMAC-SHA256).
MXM_PAGOS_WEBHOOK_SECRET=

# RODAID — Hito 16: RODAID Open-Connect (apertura al ecosistema externo).
# El acceso de terceros se basa en OAuth2/OIDC con consentimiento expreso del
# usuario. Estas variables son OPCIONALES: sin ellas el modulo opera de punta a
# punta en preview (claves derivadas del secreto de la app, igual que el resto
# del proyecto) y al definirlas opera en produccion sin tocar codigo.
#
# URL base publica del sitio (para issuer/redirect/verifier del flujo OAuth y de
# las Credenciales Verificables). Si esta vacia, se deriva del request.
RODAID_BASE_URL=
# Vida (segundos) del access token OAuth2 que consumen los terceros. Por defecto 3600.
RODAID_OAUTH_TOKEN_TTL_SEG=3600
# Clave PRIVADA de firma de las Credenciales Verificables (W3C VC-JWT, EdDSA), en
# formato JWK (OKP/Ed25519) como JSON. La clave publica se publica en
# /.well-known/jwks.json y /.well-known/did.json. Sin esta variable se deriva una
# clave Ed25519 estable del secreto de la app (preview).
RODAID_VC_SIGNING_JWK=
