// ─── RODAID · Prisma Schema ───────────────────────────────
// PostgreSQL · Ley 9556 Mendoza · BFA · NFT ERC-721

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Cole a sua URL completa aqui, sem depender de process.env
  url      = "postgresql://neondb_owner:A_SUA_PASSWORD_REAL@ep-solitary-dawn-atoqtsfx-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

// ── Enums ─────────────────────────────────────────────────

enum RolUsuario {
  CICLISTA
  INSPECTOR
  ALIADO
  ADMIN
}

enum EstadoCIT {
  PENDIENTE       // Dentro del período de 72 hs de validación
  ACTIVO          // CIT emitido y NFT acuñado en BFA
  RECHAZADO       // Coincide con denuncia activa — bloqueado
  EXPIRADO        // Vencido (12 meses)
  BLOQUEADO       // Denuncia de robo post-emisión
}

enum TipoBicicleta {
  MTB
  RUTA
  URBANA
  GRAVEL
  ELECTRICA
  BMX
  OTRO
}

enum EstadoPublicacion {
  ACTIVA
  VENDIDA
  PAUSADA
  ELIMINADA
}

enum EstadoPago {
  PENDIENTE
  EN_ESCROW
  LIBERADO
  DEVUELTO
  FALLIDO
}

enum TipoNotificacion {
  CIT_APROBADO
  CIT_RECHAZADO
  CIT_POR_VENCER
  DENUNCIA_REGISTRADA
  BICI_RECUPERADA
  NUEVA_OFERTA
  VENTA_CONFIRMADA
}

// ── Modelos ───────────────────────────────────────────────

model Usuario {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String?
  nombre          String
  apellido        String
  dni             String?       @unique
  cuil            String?       @unique
  telefono        String?
  rol             RolUsuario    @default(CICLISTA)
  planId          String?
  plan            Plan?         @relation(fields: [planId], references: [id])
  mxmVerificado   Boolean       @default(false)
  mxmNivel        Int           @default(0)     // 0=sin vincular, 1=básico, 2=verificado
  mxmToken        String?       // Token OAuth MxM (encriptado)
  deviceTokens    DeviceToken[]
  bicicletas      Bicicleta[]
  publicaciones   Publicacion[]
  compras         Transaccion[] @relation("Comprador")
  ventas          Transaccion[] @relation("Vendedor")
  notificaciones  Notificacion[]
  refreshTokens   RefreshToken[]
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  @@map("usuarios")
}

model Inspector {
  id              String        @id @default(uuid())
  usuarioId       String        @unique
  usuario         Usuario       @relation(fields: [usuarioId], references: [id])
  tallerAliado    TallerAliado  @relation(fields: [tallerAliadoId], references: [id])
  tallerAliadoId  String
  certificado     Boolean       @default(false)
  citsEmitidos    CIT[]
  creadoEn        DateTime      @default(now())

  @@map("inspectores")
}

model TallerAliado {
  id              String        @id @default(uuid())
  nombre          String
  direccion       String
  localidad       String
  provincia       String        @default("Mendoza")
  lat             Float?
  lng             Float?
  inspectores     Inspector[]
  citsEmitidos    CIT[]
  plan            String        @default("base")  // base | plus | fundador
  activo          Boolean       @default(true)
  creadoEn        DateTime      @default(now())

  @@map("talleres_aliados")
}

model Plan {
  id              String        @id @default(uuid())
  nombre          String        @unique  // libre | estandar | premium
  precioUSD       Float
  citLimite       Int?          // null = ilimitado
  features        String[]
  usuarios        Usuario[]

  @@map("planes")
}

model Bicicleta {
  id              String        @id @default(uuid())
  propietarioId   String
  propietario     Usuario       @relation(fields: [propietarioId], references: [id])
  numeroSerie     String        @unique
  marca           String
  modelo          String
  anio            Int
  tipo            TipoBicicleta
  color           String?
  fotos           String[]      // URLs en S3
  cits            CIT[]
  publicaciones   Publicacion[]
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  @@map("bicicletas")
}

model CIT {
  id              String        @id @default(uuid())
  numeroCIT       String        @unique  // RCIT-YYYY-XXXXX
  bicicletaId     String
  bicicleta       Bicicleta     @relation(fields: [bicicletaId], references: [id])
  propietarioId   String        // desnormalizado para acceso rápido
  inspectorId     String
  inspector       Inspector     @relation(fields: [inspectorId], references: [id])
  tallerAliadoId  String
  tallerAliado    TallerAliado  @relation(fields: [tallerAliadoId], references: [id])
  estado          EstadoCIT     @default(PENDIENTE)
  puntos          Int           // /20
  puntoDetalle    Json          // { "serial": true, "cuadro": true, ... }
  hashSHA256      String        @unique
  bfaTxHash       String?       // Hash de la tx en BFA
  nftTokenId      Int?          // ID del NFT ERC-721 en BFA
  firmaInspector  String        // Firma digital PKCS#7
  fotos           String[]      // URLs S3 — protocolo de inspección
  djFirmada       Boolean       @default(false)
  djFirmadaEn     DateTime?
  fechaEmision    DateTime?     // Cuando pasa de PENDIENTE a ACTIVO
  fechaVencimiento DateTime?    // fechaEmision + 12 meses
  kmAuditados     Int           @default(0)
  mxmExpediente   String?       // ID expediente en sistema MxM
  mxmPagoId       String?       // ID pago tasa CIT en MxM Pagos
  notas           String?
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  @@map("cits")
}

model ValidacionQueue {
  id              String        @id @default(uuid())
  citId           String        @unique
  serialBicicleta String
  propietarioDNI  String
  propietarioNombre String
  propietarioDatos Json         // Foto, geoloc, contacto — para denuncia si hay alerta
  iniciadaEn      DateTime      @default(now())
  venceEn         DateTime      // iniciadaEn + 72 hs hábiles
  procesadaEn     DateTime?
  resultado       String?       // "aprobado" | "rechazado"
  alertaMinSeg    Boolean       @default(false)
  detalleAlerta   Json?

  @@map("validacion_queue")
}

model Publicacion {
  id              String            @id @default(uuid())
  vendedorId      String
  vendedor        Usuario           @relation(fields: [vendedorId], references: [id])
  bicicletaId     String
  bicicleta       Bicicleta         @relation(fields: [bicicletaId], references: [id])
  titulo          String
  descripcion     String?
  precioARS       Float
  estado          EstadoPublicacion @default(ACTIVA)
  transacciones   Transaccion[]
  vistasCount     Int               @default(0)
  creadoEn        DateTime          @default(now())
  actualizadoEn   DateTime          @updatedAt

  @@map("publicaciones")
}

model Transaccion {
  id              String      @id @default(uuid())
  publicacionId   String
  publicacion     Publicacion @relation(fields: [publicacionId], references: [id])
  compradorId     String
  comprador       Usuario     @relation("Comprador", fields: [compradorId], references: [id])
  vendedorId      String
  vendedor        Usuario     @relation("Vendedor", fields: [vendedorId], references: [id])
  montoARS        Float
  comisionARS     Float       // 2.5% RODAID
  estadoPago      EstadoPago  @default(PENDIENTE)
  mpPreferenceId  String?
  mpPaymentId     String?
  escrowLiberadoEn DateTime?
  nftTransferTxHash String?
  creadoEn        DateTime    @default(now())
  actualizadoEn   DateTime    @updatedAt

  @@map("transacciones")
}

model Notificacion {
  id              String           @id @default(uuid())
  usuarioId       String
  usuario         Usuario          @relation(fields: [usuarioId], references: [id])
  tipo            TipoNotificacion
  titulo          String
  cuerpo          String
  datos           Json?
  leida           Boolean          @default(false)
  enviadaMxM      Boolean          @default(false)
  creadoEn        DateTime         @default(now())

  @@map("notificaciones")
}

model DeviceToken {
  id              String    @id @default(uuid())
  usuarioId       String
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  token           String    @unique
  plataforma      String    // "web" | "android" | "ios"
  creadoEn        DateTime  @default(now())

  @@map("device_tokens")
}

model RefreshToken {
  id              String    @id @default(uuid())
  usuarioId       String
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  token           String    @unique
  expiresAt       DateTime
  creadoEn        DateTime  @default(now())

  @@map("refresh_tokens")
}
