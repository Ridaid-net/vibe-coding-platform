# ─── RODAID API · Variables de Entorno ───────────────────
# Copiar como .env y completar con valores reales

# ── Servidor ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ── Base de datos (PostgreSQL) ────────────────────────────
DATABASE_URL="postgresql://rodaid_user:password@localhost:5432/rodaid_db"

# ── Redis (colas y caché) ─────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="CAMBIAR_POR_SECRETO_256_BITS_REAL"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,https://rodaid.com.ar"

# ── Blockchain Federal Argentina (BFA) ───────────────────
BFA_RPC_URL="https://public.nodo1.afip.gob.ar"
BFA_CHAIN_ID=1
BFA_WALLET_PRIVATE_KEY="0x_CLAVE_PRIVADA_WALLET_RODAID"
BFA_CONTRACT_ADDRESS="0x_DIRECCION_CONTRATO_CIT_DESPUES_DE_DEPLOY"

# ── MendozaxMi OAuth 2.0 ─────────────────────────────────
MXM_CLIENT_ID="SOLICITAR_A_GOBIERNO_MENDOZA"
MXM_CLIENT_SECRET="SOLICITAR_A_GOBIERNO_MENDOZA"
MXM_AUTH_URL="https://mxm.mendoza.gov.ar/oauth/authorize"
MXM_TOKEN_URL="https://mxm.mendoza.gov.ar/oauth/token"
MXM_REDIRECT_URI="https://api.rodaid.com.ar/v1/auth/mxm/callback"
MXM_PAGOS_URL="https://mxm.mendoza.gov.ar/api/pagos"
MXM_NOTIF_URL="https://mxm.mendoza.gov.ar/api/notificaciones"
MXM_TRAMITES_URL="https://mxm.mendoza.gov.ar/api/tramites"

# ── Almacenamiento (S3 compatible — AWS / Cloudflare R2) ─
STORAGE_ENDPOINT="https://s3.us-east-1.amazonaws.com"
STORAGE_BUCKET="rodaid-cit-docs"
STORAGE_ACCESS_KEY="COMPLETAR"
STORAGE_SECRET_KEY="COMPLETAR"

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY="re_COMPLETAR"
EMAIL_FROM="noreply@rodaid.com.ar"

# ── MercadoPago ──────────────────────────────────────────
MP_ACCESS_TOKEN="APP_USR_COMPLETAR"
MP_WEBHOOK_SECRET="COMPLETAR"

# ── Ministerio de Seguridad Mendoza ──────────────────────
# Pendiente de acuerdo técnico formal
MINSEG_API_URL="https://api.seguridadmendoza.gob.ar"
MINSEG_API_KEY="PENDIENTE_CONVENIO"
MINSEG_CERT_PATH="./certs/minseg-client.p12"

# ── Anthropic (RODAID-GPT) ───────────────────────────────
ANTHROPIC_API_KEY="sk-ant-COMPLETAR"

# ── Firebase (Push Notifications) ────────────────────────
FCM_PROJECT_ID="rodaid-prod"
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCOMPLETAR\n-----END PRIVATE KEY-----"
FCM_CLIENT_EMAIL="firebase-adminsdk@rodaid-prod.iam.gserviceaccount.com"
